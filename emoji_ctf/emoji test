<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Welcome to Emoji Corp</title>
     <style>
        /* PAGE STYLE */
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #0f172a;
            font-family: Times New Roman; /* system font */
            color: #f1f5f9;
        }

        /* CARD CONTAINER */
        .container {
            background: #1e293b;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
            max-width: 700px;
            text-align: center;
        }

        /* TITLE */
        h1 {
            margin-top: 0;
            color: #38bdf8;
            transition: all 0.3s ease;
            cursor: pointer;
            letter-spacing: 1px;
        }

        /* HOVER EFFECT */
        h1:hover {
            color: #7dd3fc;
            text-shadow:
                0 0 10px #38bdf8,
                0 0 20px #38bdf8,
                0 0 40px #0ea5e9;
            transform: scale(1.05);
        }

        /* NORMAL TEXT */
        p {
            line-height: 1.6;
            font-size: 18px;
        }

        /* FLAG STYLE (CONTENT UNCHANGED) */
        p:last-child {
            background: #020617;
            padding: 15px;
            border-radius: 8px;
            font-family: "Courier New", Consolas, monospace;
            overflow-x: auto;
            word-break: break-word;
        }
    </style>
</head>
<body>
<div class="container">
    <h1>Welcome to Emoji Corporation</h1>
    <p>We value privacy and security.</p>

    <p>
    FLAG:
    👤🐹👠👫👪👲👧👦👮👜👩👖🐹👜👣👦👥👞👪👖👫👦👖👫👟👜👖👧👜👦👧👣👜👴🐗
    </p>

</body>
</html>
